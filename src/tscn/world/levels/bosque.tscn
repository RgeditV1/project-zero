[sub_resource type="GDScript" id="GDScript_88785"]
script/source = "extends Node2D

@onready var player:= $Player

@export var layers: Array[Parallax2D]

#scroll_offset for the parallax layers
@export var speeds: Array[float]

var last_position: Vector2

func _ready() -> void:
	last_position.x = player.global_position.x

func _process(_delta):
	var movement = player.global_position - last_position

	for i in layers.size():
		layers[i].scroll_offset.x += movement.x * speeds[i]

	last_position = player.global_position
"

